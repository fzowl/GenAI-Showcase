# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
DATABASE_NAME=video_intelligence

# AI Service API Keys
VOYAGE_AI_API_KEY=your_voyage_ai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Application Settings
UPLOAD_DIR=uploads
FRAMES_DIR=frames
MAX_FILE_SIZE_MB=1024
FRAME_EXTRACTION_INTERVAL=2

# CORS Settings (for development)
FRONTEND_URL=http://localhost:3000

# Embedding config
EMBEDDING_DIM_SIZE=1024

# Demo/fallback mode (set to "true" to skip real API calls)
DEMO_FALLBACK_MODE=false
